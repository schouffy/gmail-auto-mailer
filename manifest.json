{
  "manifest_version": 3,
  "name": "Gmail Auto Sender",
  "version": "0.1",
  "description": "Automate Gmail sending from CSV",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://mail.google.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"]
    }
  ]
}